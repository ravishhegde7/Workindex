{
  "rewrites": [
    { "source": "/expert/:id", "destination": "/index.html" },
    { "source": "/((?!app\\.js|styles\\.css|admin\\.css|admin-app\\.js|admin\\.html|favicon\\.ico).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}
